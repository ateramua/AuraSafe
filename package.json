{
  "name": "aurasafe",
  "version": "0.1.0",
  "description": "A spiritual, mindful password manager desktop app with browser extensions",
  "author": "AuraSafe Team",
  "main": "electron/main/index.mjs",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "concurrently \"next dev -p 3000\" \"wait-on http://localhost:3000 && NODE_ENV=development AURASAFE_DEV_URL=http://localhost:3000 electron .\"",
    "electron:prod": "npm run build && concurrently \"serve -s out -l 3000\" \"wait-on http://localhost:3000 && electron .\"",
    "start": "electron .",
    "dist": "npm run clean && npm run build && electron-builder",
    "clean": "rimraf .next out release dist",
    "extension:platform:build": "node extensions/platform/scripts/build-extension.mjs all",
    "extension:platform:chromium": "node extensions/platform/scripts/build-extension.mjs chromium",
    "extension:platform:firefox": "node extensions/platform/scripts/build-extension.mjs firefox",
    "extension:platform:package": "npm run extension:platform:build && node extensions/platform/scripts/package-extension.mjs all",
    "extension:platform:package:chromium": "npm run extension:platform:chromium && node extensions/platform/scripts/package-extension.mjs chromium",
    "extension:platform:package:firefox": "npm run extension:platform:firefox && node extensions/platform/scripts/package-extension.mjs firefox",
    "extension:platform:test": "node --test extensions/platform/tests/*.test.mjs",
    "extension:platform:validate": "node extensions/platform/scripts/validate-extension.mjs"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "electron-context-menu": "^4.0.0",
    "electron-store": "^9.0.0",
    "electron-updater": "^6.3.9",
    "express": "^4.18.3",
    "idb": "^8.0.3",
    "ipfs-http-client": "^60.0.1",
    "keytar": "^7.9.0",
    "next": "^14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.20.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "open-cli": "^7.2.0",
    "rimraf": "^6.0.1",
    "serve": "^14.2.6",
    "wait-on": "^9.0.4",
    "web-ext": "^7.5.0"
  },
  "build": {
    "appId": "com.aurasafe.app",
    "productName": "AuraSafe",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sqlite3",
      "node_modules/keytar"
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "out",
        "to": "out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron/preload/",
        "to": "preload"
      },
      {
        "from": "src/db/data/",
        "to": "db/data/"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/icon.png"
    }
  }
}
