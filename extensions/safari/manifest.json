{
  "manifest_version": 3,
  "name": "AuraSafe",
  "version": "2.0.0",
  "description": "AuraSafe Password Manager Extension",
  
  "permissions": [
    "storage",
    "activeTab"
  ],
  
  "host_permissions": [
    "http://localhost:3456/",
    "http://localhost:3000/",
    "<all_urls>"
  ],
  
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "AuraSafe"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "options_ui": {
    "page": "options.html"
  }
}