{
  "manifest_version": 3,
  "name": "AuraSafe Companion",
  "version": "0.1.0",
  "description": "Premium browser companion for AuraSafe desktop vault, autofill, and secure productivity workflows.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background/service-worker.js"
    ],
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AuraSafe Companion",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "aurasafe-companion@example.com",
      "strict_min_version": "112.0"
    }
  }
}
