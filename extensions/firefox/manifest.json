{
  "manifest_version": 2,
  "name": "AuraSafe",
  "version": "2.0.0",
  "description": "AuraSafe Password Manager Extension",
  
  "permissions": [
    "storage",
    "http://localhost:3456/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*"
  ],
  
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "AuraSafe"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  
  "browser_specific_settings": {
    "gecko": {
      "id": "aurasafe@aurasafe.com",
      "strict_min_version": "109.0"
    }
  }
}