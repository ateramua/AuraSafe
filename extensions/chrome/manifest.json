{
  "manifest_version": 3,
  "name": "AuraSafe Password Manager",
  "version": "0.1.0",
  "description": "Access your vault from the browser",
  "permissions": ["activeTab", "storage", "webNavigation"],
  "host_permissions": ["http://localhost:8765/*","ws://localhost:8765/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}